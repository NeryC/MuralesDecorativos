# ============================================================
# Supabase - Desarrollo Local (Supabase CLI)
# ============================================================
# 1. Instalá Supabase CLI: https://supabase.com/docs/guides/cli
# 2. Corré: yarn db:start
# 3. Copiá las keys del output (ANON KEY) y pegá abajo
# 4. Copiá este archivo: cp .env.local.example .env.local

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key del output de yarn db:start>

# ============================================================
# Supabase - Producción (Supabase Cloud)
# ============================================================
# Descomentar y completar para producción:
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxx

# ============================================================
# Cloudflare Turnstile (anti-spam) — opcional pero recomendado en prod
# ============================================================
# 1. Crear sitio gratis en https://dash.cloudflare.com/?to=/:account/turnstile
# 2. Pegá la site key (pública) y la secret (server-side).
# Si no se definen, la app omite la verificación de captcha.

# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAAAAA
# TURNSTILE_SECRET_KEY=0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ============================================================
# Sentry (observabilidad de errores) — opcional pero recomendado en prod
# ============================================================
# 1) Crear proyecto Next.js gratis en https://sentry.io
# 2) Copiar el DSN del proyecto (Settings → Client Keys (DSN)).
# 3) En Vercel: agregar también SENTRY_AUTH_TOKEN (Org → Auth Tokens, scope project:write)
#    para que el build suba sourcemaps automáticamente.
# Si SENTRY_DSN está vacío, instrumentation.ts no inicializa Sentry y se usa console.

# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ============================================================
# Resend (notificaciones por email cuando entra un nuevo mural pendiente)
# ============================================================
# 1) Crear cuenta gratis en https://resend.com (free tier: 3.000 emails/mes)
# 2) API Keys → Create API Key (full access). Copiar y pegar en RESEND_API_KEY.
# 3) NOTIFY_EMAIL = correo que recibe la notificación.
# 4) (Opcional) RESEND_FROM con dominio verificado; sin esto se usa
#    "onboarding@resend.dev" que sirve para test pero entrega marcado.
# Si RESEND_API_KEY o NOTIFY_EMAIL están vacíos, el envío es no-op (no rompe nada).

# RESEND_API_KEY=
# NOTIFY_EMAIL=
# RESEND_FROM="Murales Políticos <notificaciones@tu-dominio.com>"
